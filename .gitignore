# macOS
.DS_Store

# Claude Code local config
.claude/
AGENTS.md

# Cortex local storage — ignore everything under .context/ except the three
# editable config files. Matches the convention `cortex init` generates for
# downstream repos (see bin/cortex.mjs:GITIGNORE_LINES).
.context/*
!.context/config.yaml
!.context/rules.yaml
!.context/ontology.cypher

# scaffold/.context/ subdirs are narrow because the scaffold ships .context/
# configs and notes as tracked files; we only ignore the generated subdirs.
scaffold/.context/db/
scaffold/.context/embeddings/
scaffold/.context/cache/
scaffold/.context/plan/
scaffold/.context/hooks/
scaffold/.context/telemetry/
.npm-cache/

# Node
node_modules/
scripts/parsers/node_modules
*.log
mcp/.npm-cache/

# Build output
/mcp/
scaffold/mcp/dist/
scaffold/scripts/parsers/dotnet/**/bin/
scaffold/scripts/parsers/dotnet/**/obj/
scripts/parsers/dotnet/**/bin/
scripts/parsers/dotnet/**/obj/

# Bootstrapbench runtime artifacts
benchmark/bootstrapbench/results/
benchmark/bootstrapbench/.build/

# Frontend build output
frontend/dist/

# Release artifacts and local auth tokens
*.tgz
.mcpregistry_github_token
.mcpregistry_registry_token

# Stray mcp/ at repo root — legacy layout, kept in case dev tooling regenerates it
mcp/node_modules/
mcp/.context/
